# ═══════════════════════════════════════════════════════════════
# TRADING SIGNALS PRO — Variables de entorno
# Copia este archivo como .env para desarrollo local
# En Railway: añade estas variables en el panel de Variables
# ═══════════════════════════════════════════════════════════════

# ── APIs OBLIGATORIAS ────────────────────────────────────────────
# Alpha Vantage — datos de mercado (GRATIS en alphavantage.co)
ALPHAVANTAGE_KEY=tu_api_key_aqui

# Anthropic — análisis IA con Claude
ANTHROPIC_KEY=tu_api_key_aqui

# ── TELEGRAM (para recibir alertas en el móvil) ──────────────────
# 1. Habla con @BotFather en Telegram → /newbot → copia el token
# 2. Habla con @userinfobot para obtener tu chat_id
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=tu_chat_id_numerico

# ── CONFIGURACIÓN DE LA ESTRATEGIA ───────────────────────────────
# Intervalo entre ciclos en segundos (14400 = 4 horas)
CHECK_INTERVAL=14400

# Parámetros SL/TP (se recalibran automáticamente, estos son el fallback)
SL_MULT=2.0
TP_MULT=3.5

# Zona RSI para señales
RSI_LOW=38
RSI_HIGH=62

# ── ALMACENAMIENTO ───────────────────────────────────────────────
# Ruta del log de señales (Railway Volume o local)
SIGNALS_LOG_PATH=/data/signals_log.json
